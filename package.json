		"@webgpu/types": "^0.1.70",
		"eslint-plugin-solid": "^0.14.5",
		"jsdom": "^29.1.1",
		"tailwindcss": "^4.3.3",
		"typescript": "npm:@typescript/typescript6@^6.0.2",
		"vite": "catalog:",
		"vite-plugin-pwa": "^1.3.0",
		"vite-plugin-solid": "^2.11.6",
		"vite-plus": "catalog:",
		"vitest": "catalog:",
		"wabt": "^1.0.39",
		"workbox-window": "^7.4.1",
		"wrangler": "^4.112.0"
	}
