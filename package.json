	"packageManager": "pnpm@10.12.1",
	"scripts": {
		"dev": "vp dev",
		"build": "tsc --noEmit && vp build",
		"preview": "vp build && wrangler dev",
		"test": "vp test run",
		"test:watch": "vp test",
		"deploy": "vp build && wrangler deploy",
		"lint": "vp lint .",
		"format": "vp fmt .",
