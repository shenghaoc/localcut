		"clsx": "^2.1.1",
		"dompurify": "^3.4.8",
		"lucide-solid": "^1.17.0",
		"mediabunny": "^1.46.0",
		"solid-js": "^1.9.7",
		"tailwind-merge": "^3.6.0"
	},
	"devDependencies": {
		"@playwright/test": "1.60.0",
		"@tailwindcss/vite": "^4.3.0",
		"@types/node": "^25.9.3",
		"@webgpu/types": "^0.1.70",
		"eslint-plugin-solid": "^0.14.5",
		"tailwindcss": "^4.3.0",
		"typescript": "~5.8.3",
		"vite": "catalog:",
