{
	"name": "browser-editor",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"license": "MIT",
	"packageManager": "pnpm@11.6.0+sha512.9a36518224080c6fe5165afdcfe79bfa118c29be703f3f462b1e32efe1e98e47e8750b148e08286250aad4113cc7993ca413c4e2cd447752708c2ee5751bc95f",
	"scripts": {
		"dev": "vp dev",
		"build": "vp build",
		"preview": "vp build && wrangler dev",
		"test": "vp test run",
		"test:watch": "vp test",
		"test:browser": "vp test run --config vitest.browser.config.ts",
		"test:browser:watch": "vp test --config vitest.browser.config.ts",
		"deploy": "vp build && wrangler deploy",
		"lint": "vp lint . --max-warnings=0",
		"format": "vp fmt .",
		"format:check": "vp fmt --check .",
		"typecheck": "tsc --noEmit",
		"check": "vp run check:format && vp run check:lint && vp run check:typecheck && vp run check:test && vp run check:build",
		"build:wasm": "node scripts/build-wasm.mjs",
		"build:wasm:rnnoise": "node scripts/build-rnnoise-wasm.mjs",
		"build:wasm:beat": "node scripts/build-wasm-beat.mjs",
		"test:e2e": "playwright test",
		"prepare": "vp config"
	},
	"dependencies": {
		"@ark-ui/solid": "^5.37.1",
		"@fontsource/dm-sans": "^5.2.8",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"dompurify": "^3.4.12",
		"lottie-web": "^5.13.0",
		"lucide-solid": "^1.25.0",
		"marked": "^18.0.6",
		"mediabunny": "^1.50.8",
		"onnxruntime-web": "1.27.0",
		"solid-js": "^1.9.7"
	},
	"devDependencies": {
